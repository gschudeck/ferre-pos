# =====================================================
# CONFIGURACIÓN DE ENTORNO - FERRE-POS API
# =====================================================

# Configuración del servidor
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ferre_pos
DB_USER=ferre_pos_app
DB_PASSWORD=your_secure_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT y Seguridad
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FILE=logs/ferre-pos-api.log

# DTE (Documentos Tributarios Electrónicos)
DTE_PROVIDER_URL=https://api.dte-provider.cl
DTE_PROVIDER_TOKEN=your_dte_provider_token
DTE_ENVIRONMENT=certificacion

# Medios de Pago
TRANSBANK_API_URL=https://webpay3gint.transbank.cl
TRANSBANK_COMMERCE_CODE=your_commerce_code
TRANSBANK_API_KEY=your_api_key

MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key

# Fidelización
FIDELIZACION_PUNTOS_POR_PESO=1
FIDELIZACION_MINIMO_CANJE=100
FIDELIZACION_EXPIRACION_DIAS=365

# Sincronización
SYNC_INTERVAL_MINUTES=5
SYNC_BATCH_SIZE=100

# Monitoreo y Alertas
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30000

# Archivos y Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# Cache
CACHE_TTL=300
CACHE_MAX_KEYS=1000

